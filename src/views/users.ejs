<%- include('partials/header') %>
<main>
    <h1><%= title %></h1>
    <p>Here is a list of users:</p>
    <table class="users-table">
        <th>Name</th>
        <th>Email</th>
        <th>Role</th>
        <tbody>
            <% users.forEach(user => { %>
                <tr>
                    <td><%= user.name %></td>
                    <td><%= user.email %></td>
                    <td><%= user.role_name %></td>
                </tr>
            <% }); %>               
        </tbody>
     
    </table>

</main>
<%- include('partials/footer') %>