<%- include('partials/header') %>
<main>
    <h1><%= title %></h1>

 <form class="add-form" action="/edit-organization/<%= organizationDetails.organization_id %>" method="POST">
    <div class="form-group">
      <label for="name">Organization Name</label>
      <input
        type="text"
        id="name"
        name="name" 
        value="<%= organizationDetails.name %>"
        required
        maxlength="150"
      />
    </div>

    <div class="form-group">
      <label for="description">Description</label>
      <textarea
        id="description"
        name="description"
        required
        maxlength="500"
      ><%= organizationDetails.description %></textarea>
    </div>

    <div class="form-group">
      <label for="contactEmail">Contact Email</label>
      <input
        type="email"
        id="contactEmail"
        maxlength="255"
        required
        name="contactEmail"
        value="<%= organizationDetails.contact_email %>"
      />
    </div>

    <div class="form-group">
        <label for="logoFilename">Logo Filename</label>
        <input type="text"
            type="text"
            id="logoFilename"
            name="logoFilename"
            maxlength="255"
            required
            value="<%= organizationDetails.logo_filename %> "
        />
    </div>

    <button type="submit">Create Organization</button>
  </form>

</main>
<%- include('partials/footer') %>