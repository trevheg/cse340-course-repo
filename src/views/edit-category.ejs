<%- include('partials/header') %>
<main>
    <h1><%= title %></h1>

 <form class="add-form" action="/edit-category/<%= categoryDetails.category_id %>" method="POST">
    <div class="form-group">
      <label for="name">Category Name</label>
      <input
        type="text"
        id="name"
        name="name" 
        value="<%= categoryDetails.category_name %>"
        required
        maxlength="150"
      />
    </div>

    <div class="form-group">
      <label for="description">Description</label>
      <textarea
        id="description"
        name="description"
        required
        maxlength="500"
      ><%= categoryDetails.category_description %></textarea>
    </div>

    <button type="submit">Edit Category</button>
  </form>

</main>
<%- include('partials/footer') %>