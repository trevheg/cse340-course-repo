<%- include('partials/header') %>
<main>
    <h1><%= title %></h1>



 <form class="add-form" action="/new-category" method="POST">
    <div class="form-group">
      <label for="name">Category</label>
      <input
        type="text"
        id="name"
        name="name" 
        required
        maxlength="100"
      />
    </div>

    <div class="form-group">
      <label for="description">Description</label>
      <textarea
        id="description"
        name="description"
        required
        maxlength="500"
      ></textarea>
    </div>

    <button type="submit">Create Category</button>
  </form>

</main>
<%- include('partials/footer') %>