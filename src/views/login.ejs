<%- include('partials/header') %>
<main>
    <h1><%= title %></h1>
    <form class="add-form" action="/login" method="POST">
        <div class="form-group">
            <label for="email"></label>
            <input 
                type="email"
                id="email"
                name="email"
                required
                >
        </div>
        <div class="form-group">
            <label for="password"></label>
            <input 
                type="password"
                name="password"
                id="password"
                required
                >
        </div>
        <button type="submit">Log In</button>
    </form>
</main>
<%- include('partials/footer') %>