<%- include('partials/header') %>
<main>
    <h1><%= title %></h1>

 <form class="add-form" action="/edit-project/<%= projectDetails.project_id %>" method="POST">
    <div class="form-group">
      <label for="name">Project Title</label>
      <input
        type="text"
        id="title"
        name="title" 
        value="<%= projectDetails.title %>"
        required
        maxlength="150"
      />
    </div>

    <div class="form-group">
      <label for="description">Description</label>
      <textarea
        id="description"
        name="description"
        required
        maxlength="500"
      ><%= projectDetails.description %></textarea>
    </div>

    <div class="form-group">
      <label for="location">Location</label>
      <textarea
        id="location"
        name="location"
        required
        maxlength="500"
      ><%= projectDetails.location %></textarea>
    </div>

    <div class="form-group">
      <label for="date">Date</label>
      <input
        type="date"
        id="date"
        required
        name="date"
        value="<%= projectDetails.date ? projectDetails.date.toISOString().slice(0,10) : '' %>" />
      
    </div>

    <div class="form-group">
      <label for="organizationId">Organization</label>
      <select 
        id="organizationId"
        name="organizationId"
        required
        > 
        <option 
            value="" selected >Select an organization
        </option>
        <% organizations.forEach(org => { %>
        <option
            value="<%= org.organization_id %>"
            <%= (String(org.organization_id) === String(projectDetails.organization_id)) ? 'selected' : '' %>
            ><%= org.name %></option>
        <% }); %>
      </select>
    </div>

    <button type="submit">Edit Organization</button>
  </form>

</main>
<%- include('partials/footer') %>